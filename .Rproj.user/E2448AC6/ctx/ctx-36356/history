exapmple_func <- function(x , args_norm = list(mean = 0, sd = 1),
args_pois = list(lamda = 1)){
args_norm[["x"]] <- x
args_pois[["n"]] <- x
norm <- do.call(rnorm,args = args_norm)
pois <- do.call(rpois,args = args_pois)
output <- data.frame("norm" = norm, "pois" = pois)
return(output)
}
